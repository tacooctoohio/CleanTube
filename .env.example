NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-publishable-key

# Server-only: required for passkeys (DB writes + admin.generateLink after WebAuthn). Must be the "service_role" JWT from
# Dashboard → Settings → API — not the anon / publishable key. Same Supabase project as NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: public site hostname for WebAuthn rpId when it differs from the request host (e.g. apex vs www).
# WEBAUTHN_RP_ID=example.com
# WEBAUTHN_RP_NAME=CleanTube
